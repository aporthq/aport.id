# aport.id — Environment Variables
# Copy to .env.local (Next.js) and .dev.vars (Wrangler) for local development.
#
# Self-hosting: get your org credentials at https://aport.io/settings/api-keys

# ── Application ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8789
NEXT_PUBLIC_APORT_BASE_URL=http://localhost:8787

# ── APort API (required — these are YOUR org credentials) ───────────────────
APORT_API_KEY=apk_your_api_key_here
APORT_ORG_ID=ap_org_your_org_id_here
APORT_BASE_URL=http://localhost:8787

# ── Passport Defaults ──────────────────────────────────────────────────────
APORT_ASSURANCE_TYPE=kyc
APORT_ASSURANCE_LEVEL=L0

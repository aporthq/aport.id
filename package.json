{
  "name": "aport-id",
  "version": "0.1.0",
  "description": "Give your AI agent an identity — create a real APort passport in 60 seconds",
  "keywords": [
    "ai",
    "agent",
    "identity",
    "passport",
    "did",
    "aport",
    "cli"
  ],
  "license": "MIT",
  "author": "APort Technologies",
  "repository": {
    "type": "git",
    "url": "https://github.com/aporthq/aport.id"
  },
  "files": [
    "bin/aport-id",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aport-id": "./bin/aport-id"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:api": "wrangler pages dev functions --compatibility-date=2024-11-15 --port=8789",
    "build": "next build",
    "deploy": "pnpm build && wrangler pages deploy ./out --project-name=aport-id",
    "deploy:prod": "pnpm build && wrangler pages deploy ./out --project-name=aport-id --branch=main",
    "start": "next start",
    "serve": "npx serve@latest out -p 3000",
    "preview": "pnpm build && pnpm serve",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@cloudflare/pages-plugin-vercel-og": "^0.1.2",
    "@heroicons/react": "^2.2.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas-pro": "^2.0.2",
    "lucide-react": "^0.577.0",
    "next": "^15.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "satori": "^0.25.0",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@eslint/eslintrc": "^3.1.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0",
    "wrangler": "^3.98.0"
  }
}
